{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch PowerShell",
            "type": "coreclr",
            "request": "launch",
            "internalConsoleOptions": "neverOpen",
            "program": "${workspaceRoot}/debug/pwsh",
            "preLaunchTask": "Build",
            "console": "integratedTerminal",
            "logging": {
              // Suppresses the "Just my Code" symbol skip warnings
              "moduleLoad": false
            }
        },
        {
            "name": "Attach to Existing PowerShell",
            "type": "coreclr",
            "request": "attach",
            "justMyCode": true,
            "processId": "${command:pickProcess}",
        }
    ]
}
